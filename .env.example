# Path to your Steam library's steamapps directory.
# Example: /mnt/d/SteamLibrary/steamapps
STEAMAPPS_DIR=/mnt/d/SteamLibrary/steamapps

# Optional overrides.
# BUILD_CONFIGURATION=Release-Bep6
# GAME_DIR=/mnt/d/SteamLibrary/steamapps/common/Nuclear Option
# MOD_INSTALL_DIR=/mnt/d/SteamLibrary/steamapps/common/Nuclear Option/BepInEx/plugins/NuclearVOIP

# Optional path to a native opus runtime if you want the installer to copy it too.
# OPUS_DLL_SOURCE=/path/to/opus.dll
